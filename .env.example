# ── LLM ───────────────────────────────────────────
GEMINI_API_KEY=                  # from aistudio.google.com
GROQ_API_KEY=                    # from console.groq.com (free tier)
LLM_TIMEOUT_MS=8000              # milliseconds before Grok fallback activates
LLM_FALLBACK_ENABLED=true

# ── News & Data APIs ──────────────────────────────
NEWSAPI_KEY=                     # from newsapi.org (100 req/day free)
GDELT_ENABLED=true               # no key required
OPENWEATHER_KEY=                 # from openweathermap.org

# ── Shipping (AIS vessel tracking — free) ─────────
AISSTREAM_API_KEY=               # from aisstream.io (free, sign up via GitHub)
AISSTREAM_ENABLED=true           # set false to disable live AIS tracking

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://supplyguard:supplyguard@localhost:5432/supplyguard
REDIS_URL=redis://localhost:6379

# ── Graph DB ──────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
USE_NETWORKX=true                # true = use in-memory NetworkX (no Neo4j needed for dev)

# ── ML Service ────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
HF_MODEL_PATH=./ml/models/distilbert-disruption-v1
NLP_CONFIDENCE_THRESHOLD=0.55
GRAPH_DECAY_FACTOR=0.7
GRAPH_MAX_DEPTH=6

# ── App ───────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
PORT=3001
