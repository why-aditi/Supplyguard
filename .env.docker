# ── Docker Environment Overrides ─────────────────────
# Container-aware URLs (service names replace localhost)

# LLM
GEMINI_API_KEY=
GROQ_API_KEY=
LLM_TIMEOUT_MS=8000
LLM_FALLBACK_ENABLED=true

# Shipping
AISSTREAM_API_KEY=
AISSTREAM_ENABLED=true

# Database (Docker service names)
DATABASE_URL=postgresql://supplyguard:supplyguard@postgres:5432/supplyguard
REDIS_URL=redis://redis:6379

# ML Service (Docker service name)
ML_SERVICE_URL=http://ml:8000
NLP_CONFIDENCE_THRESHOLD=0.55
GRAPH_DECAY_FACTOR=0.7
GRAPH_MAX_DEPTH=6

# App
PORT=3001
